{
  "name": "decops-mesh-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:prompt-eval": "vitest run src/test/services/ai/promptEval.test.ts",
    "test:behavior-eval": "vitest run src/test/services/ai/behaviorEval.test.ts",
    "test:behavior-trace-batch": "vitest run src/test/services/ai/behaviorTraceBatch.test.ts",
    "test:agent-evals": "npm run test:prompt-eval && npm run test:behavior-eval && npm run test:behavior-trace-batch",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "prune": "ts-prune -p tsconfig.json"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@helia/dag-cbor": "^5.1.1",
    "@helia/dag-json": "^5.1.1",
    "@helia/json": "^5.1.1",
    "@helia/strings": "^5.1.1",
    "@helia/unixfs": "^7.2.1",
    "@libp2p/bootstrap": "^12.0.20",
    "@libp2p/circuit-relay-v2": "^4.2.3",
    "@libp2p/dcutr": "^3.0.18",
    "@libp2p/identify": "^4.1.3",
    "@libp2p/kad-dht": "^16.2.4",
    "@libp2p/peer-id": "^6.0.8",
    "@libp2p/ping": "^3.1.3",
    "@libp2p/pnet": "^3.0.19",
    "@libp2p/pubsub-peer-discovery": "^12.0.0",
    "@libp2p/webrtc": "^6.0.21",
    "@libp2p/websockets": "^10.1.11",
    "@multiformats/multiaddr": "^13.0.1",
    "@orbitdb/core": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.13.5",
    "didcomm": "^0.4.1",
    "dompurify": "^3.3.1",
    "helia": "^6.1.4",
    "immer": "^11.1.4",
    "kubo-rpc-client": "^7.0.0",
    "libp2p": "^3.2.4",
    "lucide-react": "^0.564.0",
    "marked": "^17.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "size-limit": "^12.1.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
